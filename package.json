{
  "name": "devenv-inspector",
  "version": "0.6.0",
  "description": "A unified GUI for viewing and managing dev runtimes and global packages",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "package": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win nsis",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.ali-aldahmani.devenv-inspector",
    "productName": "DevEnv Inspector",
    "copyright": "Copyright © 2026 Ali Aldahmani",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "build/icon.ico",
      "build/icon.icns",
      "build/icon.png"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.png"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "dmg": {
      "title": "DevEnv Inspector ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "Ali-Aldahmani",
      "repo": "devenv-inspector"
    }
  },
  "author": {
    "name": "Ali Aldahmani",
    "email": "info@bytecra.com"
  },
  "license": "MIT"
}
